// ============================================================
// PRISMA SCHEMA — Enterprise ERP System
// Core Accounting, Products, Inventory, Invoicing, Clients
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["ERP"]
}

// ============================================================
// 4.1 CORE ACCOUNTING
// ============================================================

/// Chart of Accounts — the backbone of double-entry bookkeeping
model Account {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  type      AccountType
  subType   String?  @map("sub_type")
  currency  String   @default("INR") @db.Char(3)
  isPandL   Boolean  @default(false) @map("is_p_and_l")
  parentId  String?  @map("parent_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  createdBy String?  @map("created_by") @db.Uuid

  // Relations
  parent         Account?         @relation("AccountHierarchy", fields: [parentId], references: [id])
  children       Account[]        @relation("AccountHierarchy")
  journalEntries JournalEntry[]
  snapshots      AccountSnapshot[]
  
  // Client linked accounts
  customerClients Client[] @relation("CustomerAccount")
  vendorClients   Client[] @relation("VendorAccount")
  
  // Product income accounts
  products       Product[] @relation("IncomeAccount")

  // Bank relation
  bankAccount    BankAccount?

  @@index([type], map: "idx_accounts_type")
  @@map("accounts")
  @@schema("ERP")
}

enum AccountType {
  Asset
  Liability
  Equity
  Revenue
  Expense

  @@schema("ERP")
}

/// Transactions — the container for balanced journal entries
/// Once posted_at is set, this record is IMMUTABLE
model Transaction {
  id          String    @id @default(uuid()) @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  postedAt    DateTime? @map("posted_at") @db.Timestamptz()
  description String?
  referenceId String?   @map("reference_id")
  invoiceId   String?   @map("invoice_id") @db.Uuid
  receiptId   String?   @map("receipt_id") @db.Uuid
  paymentId   String?   @map("payment_id") @db.Uuid
  createdBy   String?   @map("created_by") @db.Uuid
  metadata    Json?

  // Relations
  journalEntries JournalEntry[]
  invoice        Invoice? @relation(fields: [invoiceId], references: [id])
  receipt        Receipt? @relation(fields: [receiptId], references: [id])
  payment        Payment? @relation(fields: [paymentId], references: [id])
  
  // Inventory movements linked to this transaction
  inventoryMovements InventoryMovement[]

  @@map("transactions")
  @@schema("ERP")
}

/// Journal Entries — individual debit/credit lines
/// Amount is signed: positive = debit, negative = credit
/// The SUM of all entries in a transaction MUST equal zero
model JournalEntry {
  id            String   @id @default(uuid()) @db.Uuid
  transactionId String   @map("transaction_id") @db.Uuid
  accountId     String   @map("account_id") @db.Uuid
  amount        Decimal  @db.Decimal(18, 2) // signed: +debit, -credit
  entryType     EntryType @map("entry_type")
  currency      String   @default("INR") @db.Char(3)
  taxCode       String?  @map("tax_code")
  warehouseId   String?  @map("warehouse_id") @db.Uuid
  costLayerId   String?  @map("cost_layer_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  transaction Transaction @relation(fields: [transactionId], references: [id])
  account     Account     @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt], map: "idx_journal_account_posted")
  @@index([transactionId], map: "idx_journal_tx")
  @@map("journal_entries")
  @@schema("ERP")
}

enum EntryType {
  Dr
  Cr

  @@schema("ERP")
}

/// Account Snapshots — month-end balance snapshots for fast queries
/// Live Balance = snapshot.balance + SUM(entries after snapshot end)
model AccountSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  accountId   String   @map("account_id") @db.Uuid
  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end") @db.Date
  balance     Decimal  @db.Decimal(18, 2)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  account Account @relation(fields: [accountId], references: [id])

  @@unique([accountId, periodStart, periodEnd], map: "ux_snapshot_account_period")
  @@map("account_snapshots")
  @@schema("ERP")
}

// ============================================================
// 4.2 PRODUCTS & INVENTORY
// ============================================================

/// Product catalog with HSN codes and GST configuration
model Product {
  id                     String   @id @default(uuid()) @db.Uuid
  sku                    String   @unique
  name                   String
  hsnCode                String?  @map("hsn_code") // Using existing hsnCode, keeping it here for reference
  defaultUom             String?  @map("default_uom")
  isStocked              Boolean  @default(true) @map("is_stocked")
  defaultIncomeAccountId String?  @map("default_income_account_id") @db.Uuid
  gstRate                Decimal? @map("gst_rate") @db.Decimal(5, 2)
  gstType                GstType? @map("gst_type")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  defaultIncomeAccount Account?           @relation("IncomeAccount", fields: [defaultIncomeAccountId], references: [id])
  costLayers           CostLayer[]
  inventoryMovements   InventoryMovement[]
  invoiceLines         InvoiceLine[]
  brokerageTrades      Trade[]

  @@map("products")
  @@schema("ERP")
}

enum GstType {
  CGST_SGST
  IGST

  @@schema("ERP")
}

/// Cost Layers for FIFO/LIFO inventory costing
model CostLayer {
  id           String   @id @default(uuid()) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  warehouseId  String?  @map("warehouse_id") @db.Uuid
  qty          Decimal  @db.Decimal(18, 4)
  unitCost     Decimal  @map("unit_cost") @db.Decimal(18, 4)
  receivedAt   DateTime @default(now()) @map("received_at") @db.Timestamptz()
  remainingQty Decimal  @map("remaining_qty") @db.Decimal(18, 4)

  // Relations
  product Product @relation(fields: [productId], references: [id])

  @@index([productId, receivedAt], map: "idx_cost_layers_product")
  @@map("cost_layers")
  @@schema("ERP")
}

/// Inventory Movements — receipt, issue, transfer, adjustment
model InventoryMovement {
  id           String       @id @default(uuid()) @db.Uuid
  productId    String       @map("product_id") @db.Uuid
  warehouseId  String?      @map("warehouse_id") @db.Uuid
  movementType MovementType @map("movement_type")
  qty          Decimal      @db.Decimal(18, 4)
  unitCost     Decimal?     @map("unit_cost") @db.Decimal(18, 4)
  relatedTxId  String?      @map("related_tx_id") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  product      Product      @relation(fields: [productId], references: [id])
  transaction  Transaction? @relation(fields: [relatedTxId], references: [id])

  @@map("inventory_movements")
  @@schema("ERP")
}

enum MovementType {
  receipt
  issue
  transfer
  adjustment

  @@schema("ERP")
}

// ============================================================
// 4.3 INVOICING & DOCUMENTS
// ============================================================

/// Invoice header with e-invoicing fields (IRN, QR, e-Way Bill)
model Invoice {
  id              String        @id @default(uuid()) @db.Uuid
  invoiceNumber   String?       @unique @map("invoice_number")
  type            InvoiceType
  date            DateTime      @db.Date
  clientId        String?       @map("client_id") @db.Uuid
  billingAddress  Json?         @map("billing_address")
  shippingAddress Json?         @map("shipping_address")
  currency        String        @default("INR") @db.Char(3)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(18, 2)
  totalTax        Decimal       @map("total_tax") @db.Decimal(18, 2)
  status          InvoiceStatus @default(draft)
  irn             String?       // Invoice Reference Number from IRP
  qrCode          String?       @map("qr_code")
  ewayBillNo      String?       @map("eway_bill_no")
  tradeId         String?       @map("trade_id") @db.Uuid
  cgst            Decimal?      @db.Decimal(18, 2)
  sgst            Decimal?      @db.Decimal(18, 2)
  igst            Decimal?      @db.Decimal(18, 2)
  roundOff        Decimal       @default(0) @map("round_off") @db.Decimal(18, 2)
  
  // Professional Tax Invoice Fields
  consigneeId     String?       @map("consignee_id") @db.Uuid
  buyerId         String?       @map("buyer_id") @db.Uuid
  deliveryNote    String?       @map("delivery_note")
  deliveryNoteDate DateTime?    @map("delivery_note_date") @db.Date
  paymentTerms    String?       @map("payment_terms")
  suppliersRef    String?       @map("suppliers_ref")
  otherRef        String?       @map("other_ref")
  buyersOrderNo   String?       @map("buyers_order_no")
  buyersOrderDate DateTime?     @map("buyers_order_date") @db.Date
  dispatchDocNo   String?       @map("dispatch_doc_no")
  dispatchedThrough String?     @map("dispatched_through")
  destination     String?       @map("destination")
  termsOfDelivery String?       @map("terms_of_delivery")
  bankDetails     String?       @map("bank_details")
  panNo           String?       @map("pan_no")
  notes           String?
  dueDate         DateTime?     @map("due_date") @db.Date

  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  client       Client?       @relation("InvoiceClient", fields: [clientId], references: [id])
  consignee    Client?       @relation("InvoiceConsignee", fields: [consigneeId], references: [id])
  buyer        Client?       @relation("InvoiceBuyer", fields: [buyerId], references: [id])
  trade        Trade?        @relation(fields: [tradeId], references: [id])
  lines        InvoiceLine[]
  transactions Transaction[]
  receipts     Receipt[]

  @@index([clientId, date], map: "idx_invoice_client")
  @@map("invoices")
  @@schema("ERP")
}

enum InvoiceType {
  TaxInvoice
  Proforma
  CreditNote
  DebitNote

  @@schema("ERP")
}

enum InvoiceStatus {
  draft
  posted
  cancelled

  @@schema("ERP")
}

/// Invoice line items with HSN, GST, and cost layer references
model InvoiceLine {
  id           String   @id @default(uuid()) @db.Uuid
  invoiceId    String   @map("invoice_id") @db.Uuid
  productId    String?  @map("product_id") @db.Uuid
  description  String?
  qty          Decimal  @db.Decimal(18, 4)
  unitPrice    Decimal  @map("unit_price") @db.Decimal(18, 4)
  per          String?  // Unit of measure (e.g. NOS, BAGS, PCS)
  discount     Decimal  @default(0) @db.Decimal(18, 4)
  lineNet      Decimal  @map("line_net") @db.Decimal(18, 4)
  gstRate      Decimal? @map("gst_rate") @db.Decimal(5, 2)
  gstAmount    Decimal? @map("gst_amount") @db.Decimal(18, 2)
  hsnCode      String?  @map("hsn_code")
  warehouseId  String?  @map("warehouse_id") @db.Uuid
  costLayerIds String?  @map("cost_layer_ids") // JSON array of consumed layer UUIDs

  // Relations
  invoice Invoice  @relation(fields: [invoiceId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@map("invoice_lines")
  @@schema("ERP")
}

// ============================================================
// 4.3.5 EXPENSES (VENDOR BILLS & ITC)
// ============================================================

/// Vendor Bills to track Input Tax Credit (ITC)
model VendorBill {
  id              String         @id @default(uuid()) @db.Uuid
  vendorId        String         @map("vendor_id") @db.Uuid
  billNumber      String         @map("bill_number")
  date            DateTime       @db.Date
  description     String?
  totalAmount     Decimal        @map("total_amount") @db.Decimal(18, 2)
  cgst            Decimal        @default(0) @db.Decimal(18, 2)
  sgst            Decimal        @default(0) @db.Decimal(18, 2)
  igst            Decimal        @default(0) @db.Decimal(18, 2)
  hsnSac          String?        @map("hsn_sac")
  status          BillStatus     @default(draft)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  vendor          Client         @relation(fields: [vendorId], references: [id])
  payments        Payment[]

  @@unique([vendorId, billNumber])
  @@index([date, status])
  @@map("vendor_bills")
  @@schema("ERP")
}

enum BillStatus {
  draft
  posted
  paid
  cancelled

  @@schema("ERP")
}

// ============================================================
// 4.4 CLIENTS & KYC
// ============================================================

/// Client profiles (Buyer, Vendor, or Both)
model Client {
  id                  String       @id @default(uuid()) @db.Uuid
  code                String       @unique
  name                String
  type                ClientType
  defaultCurrency     String       @default("INR") @map("default_currency") @db.Char(3)
  defaultPaymentTerms String?      @map("default_payment_terms")
  customerAccountId   String?      @map("customer_account_id") @db.Uuid
  vendorAccountId     String?      @map("vendor_account_id") @db.Uuid
  gstin               String?
  placeOfSupply       String?      @map("place_of_supply")
  status              ClientStatus @default(prospect)
  email               String?
  contact             String?
  address             String?
  city                String?
  state               String?
  pincode             String?
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  customerAccount Account?        @relation("CustomerAccount", fields: [customerAccountId], references: [id])
  vendorAccount   Account?        @relation("VendorAccount", fields: [vendorAccountId], references: [id])
  history         ClientHistory[]
  kyc             ClientKyc[]
  invoices        Invoice[]       @relation("InvoiceClient")
  consigneeInvoices Invoice[]     @relation("InvoiceConsignee")
  buyerInvoices    Invoice[]      @relation("InvoiceBuyer")
  sellerTrades    Trade[]         @relation("SellerTrades")
  buyerTrades     Trade[]         @relation("BuyerTrades")
  receipts        Receipt[]
  payments        Payment[]
  tenures         Tenure[]
  vendorBills     VendorBill[]

  @@index([code, name, gstin], map: "idx_clients_search")
  @@map("clients")
  @@schema("ERP")
}

enum ClientType {
  Customer
  Vendor
  Both

  @@schema("ERP")
}

enum ClientStatus {
  prospect
  active
  onboarded
  inactive

  @@schema("ERP")
}

/// Client change history — strictly append-only
model ClientHistory {
  id         String   @id @default(uuid()) @db.Uuid
  clientId   String   @map("client_id") @db.Uuid
  changedBy  String?  @map("changed_by") @db.Uuid
  changedAt  DateTime @default(now()) @map("changed_at") @db.Timestamptz()
  changeType String   @map("change_type")
  payload    Json

  // Relations
  client Client @relation(fields: [clientId], references: [id])

  @@map("client_history")
  @@schema("ERP")
}

/// KYC document references
model ClientKyc {
  id                 String          @id @default(uuid()) @db.Uuid
  clientId           String          @map("client_id") @db.Uuid
  docType            String          @map("doc_type")
  storageRef         String          @map("storage_ref")
  uploadedBy         String?         @map("uploaded_by") @db.Uuid
  uploadedAt         DateTime        @default(now()) @map("uploaded_at") @db.Timestamptz()
  verificationStatus KycStatus       @default(pending) @map("verification_status")
  verifiedBy         String?         @map("verified_by") @db.Uuid
  verifiedAt         DateTime?       @map("verified_at") @db.Timestamptz()

  // Relations
  client Client @relation(fields: [clientId], references: [id])

  @@map("client_kyc")
  @@schema("ERP")
}

enum KycStatus {
  pending
  verified
  rejected

  @@schema("ERP")
}

// ============================================================
// 4.5 BILLING TENURES (Recurring Billing)
// ============================================================

/// Recurring billing configurations for automated invoice generation
model Tenure {
  id              String          @id @default(uuid()) @db.Uuid
  clientId        String          @map("client_id") @db.Uuid
  description     String
  amount          Decimal         @db.Decimal(18, 2)
  currency        String          @default("INR") @db.Char(3)
  frequency       TenureFrequency
  startDate       DateTime        @map("start_date") @db.Date
  endDate         DateTime?       @map("end_date") @db.Date
  nextBillingDate DateTime        @map("next_billing_date") @db.Date
  gstRate         Decimal         @default(18) @map("gst_rate") @db.Decimal(5, 2)
  status          TenureStatus    @default(active)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  client          Client          @relation(fields: [clientId], references: [id])

  @@index([clientId], map: "idx_tenures_client")
  @@index([nextBillingDate, status], map: "idx_tenures_next_billing")
  @@map("tenures")
  @@schema("ERP")
}

enum TenureFrequency {
  Monthly
  Quarterly
  Annually

  @@schema("ERP")
}

enum TenureStatus {
  active
  paused
  cancelled
  completed

  @@schema("ERP")
}

// ============================================================
// 4.6 BANK & RECEIPTS (Phase 6)
// ============================================================

/// Bank accounts mapped to ledger accounts
model BankAccount {
  id             String   @id @default(uuid()) @db.Uuid
  accountId      String   @unique @map("account_id") @db.Uuid
  bankName       String   @map("bank_name")
  accountNumber  String   @map("account_number")
  ifscCode       String?  @map("ifsc_code")
  branch         String?
  currency       String   @default("INR") @db.Char(3)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  account        Account  @relation(fields: [accountId], references: [id])
  receipts       Receipt[]
  payments       Payment[]

  @@map("bank_accounts")
  @@schema("ERP")
}

/// Incoming payments from clients (settles AR)
model Receipt {
  id               String   @id @default(uuid()) @db.Uuid
  receiptNumber    String   @unique @map("receipt_number")
  date             DateTime @db.Date
  clientId         String   @map("client_id") @db.Uuid
  bankAccountId    String   @map("bank_account_id") @db.Uuid
  amount           Decimal  @db.Decimal(18, 2)
  tdsAmount        Decimal? @map("tds_amount") @db.Decimal(18, 2)
  roundOff         Decimal  @default(0) @map("round_off") @db.Decimal(18, 2)
  currency         String   @default("INR") @db.Char(3)
  paymentMode      PaymentMode @map("payment_mode")
  referenceNumber  String?  @map("reference_number") // UTR / Cheque No
  transactionDate  DateTime? @map("transaction_date") @db.Date
  clearingDate     DateTime? @map("clearing_date") @db.Date
  notes            String?
  status           ReceiptStatus @default(posted)
  invoiceId        String?  @map("invoice_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  client           Client      @relation(fields: [clientId], references: [id])
  bankAccount      BankAccount @relation(fields: [bankAccountId], references: [id])
  invoice          Invoice?    @relation(fields: [invoiceId], references: [id])
  transactions     Transaction[]

  @@map("receipts")
  @@schema("ERP")
}

/// Outgoing payments to vendors (settles AP)
model Payment {
  id               String   @id @default(uuid()) @db.Uuid
  paymentNumber    String   @unique @map("payment_number")
  date             DateTime @db.Date
  clientId         String   @map("client_id") @db.Uuid
  bankAccountId    String   @map("bank_account_id") @db.Uuid
  amount           Decimal  @db.Decimal(18, 2)
  currency         String   @default("INR") @db.Char(3)
  paymentMode      PaymentMode @map("payment_mode")
  referenceNumber  String?  @map("reference_number") // UTR / Cheque No
  notes            String?
  status           ReceiptStatus @default(posted)
  vendorBillId     String?  @map("vendor_bill_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  client           Client      @relation(fields: [clientId], references: [id])
  bankAccount      BankAccount @relation(fields: [bankAccountId], references: [id])
  transactions     Transaction[]
  vendorBill       VendorBill? @relation(fields: [vendorBillId], references: [id])

  @@map("payments")
  @@schema("ERP")
}

enum PaymentMode {
  UPI
  NEFT
  RTGS
  IMPS
  Cheque
  Cash

  @@schema("ERP")
}

enum ReceiptStatus {
  draft
  posted
  reconciled
  cancelled

  @@schema("ERP")
}

// ============================================================
// 4.6 BROKERAGE TRADES (Data Entry)
// ============================================================

/// Commodity / Brokerage Trades
model Trade {
  id              String   @id @default(uuid()) @db.Uuid
  date            DateTime @db.Date
  sellerId        String   @map("seller_id") @db.Uuid
  buyerId         String   @map("buyer_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  quantity        Decimal  @db.Decimal(18, 4)
  price           Decimal  @db.Decimal(18, 2)
  tradeType       String   @map("trade_type") // "sell" / "buy"
  remarks         String?
  commissionRate  Decimal  @map("commission_rate") @db.Decimal(18, 2) // '@'
  commissionAmt   Decimal  @map("commission_amount") @db.Decimal(18, 2) // 'AMOUNT'
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  seller  Client  @relation("SellerTrades", fields: [sellerId], references: [id])
  buyer   Client  @relation("BuyerTrades", fields: [buyerId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  invoices Invoice[]

  @@index([date], map: "idx_trades_date")
  @@map("trades")
  @@schema("ERP")
}

// ============================================================
// 5. COMPANY & SYSTEM PREFERENCES
// ============================================================

model CompanyProfile {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  gstin     String?
  state     String?
  city      String?
  address   String?
  pincode   String?
  email     String?
  phone     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("company_profile")
  @@schema("ERP")
}

// ============================================================
// 6. USERS & ACCESS CONTROL (RBAC)
// ============================================================

enum AppRole {
  admin
  accountant
  data_entry

  @@schema("ERP")
}

/// System users with role-based access control
model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  displayName  String   @map("display_name")
  email        String?  @unique
  passwordHash String   @map("password_hash")
  role         AppRole  @default(data_entry)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("users")
  @@schema("ERP")
}

/// Dynamic policies for each role
model SystemPolicy {
  id           String   @id @default(uuid()) @db.Uuid
  role         AppRole  @unique
  permissions  Json     // { canManageLedger: boolean, ... }
  allowedViews Json     // string[]
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("system_policies")
  @@schema("ERP")
}

